print("LOOP CONTROL COMPREHENSIVE START")

var t1i = 0;
var t1sum = 0;
while(t1i < 10){
    t1i = t1i + 1;
    if(t1i % 2 == 0){
        continue
    }
    if(t1i == 9){
        break
    }
    t1sum = t1sum + t1i;
}
print("T1 WHILE CONTINUE BREAK")
print(t1sum)
print(t1sum == 16)

